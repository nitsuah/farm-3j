    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "react-resizable-panels": "^4.12.0",
    "recharts": "3.9.0",
    "sonner": "^2.0.7",
