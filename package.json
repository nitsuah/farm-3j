{
  "name": "farm-3j",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app lib components --ext .ts,.tsx,.js,.jsx --config config/eslint.config.mjs",
    "lint:fix": "eslint app lib components --ext .ts,.tsx,.js,.jsx --fix --config config/eslint.config.mjs",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\" --config config/.prettierrc --ignore-path config/.prettierignore",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\" --config config/.prettierrc --ignore-path config/.prettierignore",
    "test": "vitest run --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "test:ui": "vitest --ui --config config/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config config/vitest.config.ts",
    "type-check": "tsc --noEmit",
    "type-check:docker": "node scripts/run-in-docker.js type-check",
    "lint:docker": "node scripts/run-in-docker.js lint",
    "test:docker": "node scripts/run-in-docker.js test:coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "1.2.14",
