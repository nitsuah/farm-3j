    "@radix-ui/react-toggle": "1.1.12",
    "@radix-ui/react-toggle-group": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "detect-port": "^2.1.0",
